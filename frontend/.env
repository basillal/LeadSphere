# ==============================================================================
# LEADSPHERE FRONTEND CONFIGURATION
# ==============================================================================

# VITE_API_URL: The base URL pointing to your LeadSphere backend API.
# This tells the frontend services (like src/services/api.js) where to send data.
# Note: Vite uses 'import.meta.env.VITE_*' syntax. Variables must start with VITE_.
# (Fallback in code: '/api')
# IMPORTANT:
# - When accessing the dev frontend from another device (mobile) on your LAN,
#   using 'localhost' will point to the PHONE, not your dev machine.
# - Use the Vite dev proxy instead.
VITE_API_URL=/api
